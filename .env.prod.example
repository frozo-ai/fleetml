# FleetML Production Environment Variables
# Copy to .env.prod and fill in your values

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://fleetml:CHANGE_ME@db:5432/fleetml?sslmode=disable
POSTGRES_PASSWORD=CHANGE_ME

# ── Security ─────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# ── S3 Storage (use real AWS S3 or keep MinIO) ───────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=fleetml-models
S3_REGION=us-east-1

# ── Dodo Payments ────────────────────────────────────────
DODO_API_KEY=your_dodo_api_key
DODO_WEBHOOK_KEY=your_dodo_webhook_key
DODO_ENVIRONMENT=live
DODO_STARTER_PRODUCT_ID=prod_xxx
DODO_PRO_PRODUCT_ID=prod_yyy

# ── URLs ─────────────────────────────────────────────────
BILLING_SUCCESS_URL=https://app.fleetml.dev/dashboard/billing?success=true
BILLING_DASHBOARD_URL=https://app.fleetml.dev/dashboard
VITE_API_URL=https://api.fleetml.dev
