#!/usr/bin/env python3
"""Run inference on an ONNX model with input data from stdin.

Usage: echo '<input_bytes>' | onnx_infer --model <model_path>

Input: Raw bytes on stdin (numpy array serialized as bytes, or JSON tensor).
Output: Raw inference output bytes on stdout.
Exit code 0 on success, non-zero on failure.
"""
import argparse
import json
import sys

import numpy as np


def main():
    parser = argparse.ArgumentParser(description="ONNX Runtime inference")
    parser.add_argument("--model", required=True, help="Path to ONNX model file")
    args = parser.parse_args()

    try:
        import onnxruntime as ort

        session = ort.InferenceSession(args.model)
        input_meta = session.get_inputs()

        # Read input from stdin
        raw_input = sys.stdin.buffer.read()

        # Try to parse as JSON first (structured tensor input)
        try:
            input_data = json.loads(raw_input)
            feeds = {}
            for meta in input_meta:
                name = meta.name
                if name in input_data:
                    feeds[name] = np.array(input_data[name], dtype=_onnx_to_numpy_type(meta.type))
                else:
                    # Generate dummy input matching the expected shape
                    shape = [d if isinstance(d, int) else 1 for d in meta.shape]
                    feeds[name] = np.zeros(shape, dtype=_onnx_to_numpy_type(meta.type))
        except (json.JSONDecodeError, ValueError):
            # Raw bytes — create dummy input for all inputs
            feeds = {}
            for meta in input_meta:
                shape = [d if isinstance(d, int) else 1 for d in meta.shape]
                feeds[meta.name] = np.zeros(shape, dtype=_onnx_to_numpy_type(meta.type))

        # Run inference
        output_names = [o.name for o in session.get_outputs()]
        results = session.run(output_names, feeds)

        # Output as JSON
        output = {}
        for name, result in zip(output_names, results):
            output[name] = result.tolist()

        sys.stdout.buffer.write(json.dumps(output).encode())

    except ImportError:
        print("onnxruntime not installed", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Inference failed: {e}", file=sys.stderr)
        sys.exit(1)


def _onnx_to_numpy_type(onnx_type: str) -> np.dtype:
    """Map ONNX type string to numpy dtype."""
    mapping = {
        "tensor(float)": np.float32,
        "tensor(float16)": np.float16,
        "tensor(double)": np.float64,
        "tensor(int32)": np.int32,
        "tensor(int64)": np.int64,
        "tensor(int8)": np.int8,
        "tensor(uint8)": np.uint8,
        "tensor(bool)": np.bool_,
    }
    return mapping.get(onnx_type, np.float32)


if __name__ == "__main__":
    main()
