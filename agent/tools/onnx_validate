#!/usr/bin/env python3
"""Validate an ONNX model and output metadata as JSON.

Usage: onnx_validate --validate <model_path>

Output: JSON with input_names, output_names, opset_version on success.
Exit code 0 on valid, non-zero on invalid.
"""
import argparse
import json
import sys


def main():
    parser = argparse.ArgumentParser(description="Validate ONNX model")
    parser.add_argument("--validate", required=True, help="Path to ONNX model file")
    args = parser.parse_args()

    try:
        import onnx
        model = onnx.load(args.validate)
        onnx.checker.check_model(model)

        graph = model.graph
        metadata = {
            "input_names": [inp.name for inp in graph.input],
            "output_names": [out.name for out in graph.output],
            "opset_version": model.opset_import[0].version if model.opset_import else 0,
        }
        print(json.dumps(metadata))
    except ImportError:
        # onnx package not installed — basic file check only
        import os
        if not os.path.isfile(args.validate):
            print(f"File not found: {args.validate}", file=sys.stderr)
            sys.exit(1)
        # Check ONNX magic bytes (first 4 bytes should be the protobuf for onnx)
        with open(args.validate, "rb") as f:
            header = f.read(4)
        if len(header) < 4:
            print("File too small to be a valid ONNX model", file=sys.stderr)
            sys.exit(1)
        print(json.dumps({"input_names": [], "output_names": [], "opset_version": 0}))
    except Exception as e:
        print(f"Validation failed: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
